{
    "[python]": {
        "editor.defaultFormatter": "charliermarsh.ruff",
        "editor.formatOnSave": true,
        "editor.formatOnPaste": false,
        "editor.codeActionsOnSave": {
            "source.organizeImports": "explicit"
        }
    },
    "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
    "python.testing.unittestEnabled": false,
    "python.testing.pytestEnabled": true,
    "search.exclude": {
        "**/contracts": true,
        "**/node_modules": true,
        "**/dist": true,
        "**/.git": true,
        "**/docs/build": true    
    },
    "python.analysis.exclude": [
        "**/.venv",
        "**/venv"
    ],
    "python.analysis.include": [
        "**/tradeexecutor",
    ],    
    "python.analysis.extraPaths": [
        "${workspaceFolder}/../trade-executor/tradeexecutor",
        "${workspaceFolder}/../trade-executor/deps/web3-ethereum-defi/eth_defi",
        "${workspaceFolder}/../trade-executor/deps/trading-strategy/tradingstrategy"
    ],
    "python.analysis.diagnosticMode": "workspace",
    "[markdown]": {
        "editor.defaultFormatter": null,
         "editor.formatOnSave": false
    },
    "workbench.colorCustomizations": {
        "activityBar.activeBackground": "#009999",
        "activityBar.background": "#009999",
        "activityBar.foreground": "#e7e7e7",
        "activityBar.inactiveForeground": "#e7e7e799",
        "activityBarBadge.background": "#9f009f",
        "activityBarBadge.foreground": "#e7e7e7",
        "commandCenter.border": "#e7e7e799",
        "sash.hoverBorder": "#009999",
        "statusBar.background": "#006666",
        "statusBar.foreground": "#e7e7e7",
        "statusBarItem.hoverBackground": "#009999",
        "statusBarItem.remoteBackground": "#006666",
        "statusBarItem.remoteForeground": "#e7e7e7",
        "titleBar.activeBackground": "#006666",
        "titleBar.activeForeground": "#e7e7e7",
        "titleBar.inactiveBackground": "#00666699",
        "titleBar.inactiveForeground": "#e7e7e799"
    },
    "peacock.color": "#006666"
}